#!/bin/bash
# Git pre-commit hook for TizenClaw
# Install: ./scripts/setup-hooks.sh

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

ERRORS=0

# --------------------------------------------------
# Check 1: 80-column rule for C++ files
# --------------------------------------------------
CPP_FILES=$(git diff --cached --name-only \
  --diff-filter=ACM | grep -E '\.(cc|hh|h)$' \
  | grep -v 'nlohmann' || true)

if [ -n "${CPP_FILES}" ]; then
  for file in ${CPP_FILES}; do
    LONG_LINES=$(awk \
      'length > 80 { printf "  %s:%d (%d chars)\n", FILENAME, NR, length }' \
      "$file")
    if [ -n "${LONG_LINES}" ]; then
      echo -e "${RED}[pre-commit]${NC}" \
        "Lines > 80 chars:"
      echo "${LONG_LINES}"
      ERRORS=1
    fi
  done
fi

# --------------------------------------------------
# Check 2: Python lint (if ruff is available)
# --------------------------------------------------
PY_FILES=$(git diff --cached --name-only \
  --diff-filter=ACM | grep -E '\.py$' || true)

if [ -n "${PY_FILES}" ] && \
   command -v ruff &>/dev/null; then
  if ! ruff check ${PY_FILES} --quiet; then
    echo -e "${RED}[pre-commit]${NC}" \
      "ruff lint failed"
    ERRORS=1
  fi
fi

# --------------------------------------------------
# Result
# --------------------------------------------------
if [ "${ERRORS}" -ne 0 ]; then
  echo ""
  echo -e "${RED}[pre-commit]${NC}" \
    "Fix the issues above before committing."
  echo "  (use 'git commit --no-verify' to skip)"
  exit 1
fi

echo -e "${GREEN}[pre-commit]${NC} All checks passed."
