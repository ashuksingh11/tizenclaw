{
  "name": "agent-loop-shortcuts-runtime-contract",
  "steps": [
    {
      "name": "create-research-directory",
      "method": "bridge_tool",
      "params": {
        "tool_name": "file_manager",
        "allowed_tools": ["file_manager"],
        "args": {
          "session_id": "${unique_session_id:agent-loop-shortcuts}",
          "operation": "mkdir",
          "path": "research"
        }
      },
      "assertions": [
        {
          "path": "success",
          "equals": true
        }
      ]
    },
    {
      "name": "write-market-analysis",
      "method": "bridge_tool",
      "params": {
        "tool_name": "file_manager",
        "allowed_tools": ["file_manager"],
        "args": {
          "session_id": "${unique_session_id:agent-loop-shortcuts}",
          "operation": "write",
          "path": "research/market_analysis.txt",
          "content": "Market conditions remain stable and executive attention is needed for revenue protection."
        }
      },
      "assertions": [
        {
          "path": "success",
          "equals": true
        }
      ]
    },
    {
      "name": "write-competitor-intelligence",
      "method": "bridge_tool",
      "params": {
        "tool_name": "file_manager",
        "allowed_tools": ["file_manager"],
        "args": {
          "session_id": "${unique_session_id:agent-loop-shortcuts}",
          "operation": "write",
          "path": "research/competitor_intelligence.txt",
          "content": "Competitors moved on pricing and new launches this week."
        }
      },
      "assertions": [
        {
          "path": "success",
          "equals": true
        }
      ]
    },
    {
      "name": "write-customer-feedback",
      "method": "bridge_tool",
      "params": {
        "tool_name": "file_manager",
        "allowed_tools": ["file_manager"],
        "args": {
          "session_id": "${unique_session_id:agent-loop-shortcuts}",
          "operation": "write",
          "path": "research/customer_feedback.txt",
          "content": "Customer accounts raised support, retention, and pricing concerns."
        }
      },
      "assertions": [
        {
          "path": "success",
          "equals": true
        }
      ]
    },
    {
      "name": "write-product-updates",
      "method": "bridge_tool",
      "params": {
        "tool_name": "file_manager",
        "allowed_tools": ["file_manager"],
        "args": {
          "session_id": "${unique_session_id:agent-loop-shortcuts}",
          "operation": "write",
          "path": "research/product_updates.txt",
          "content": "Product shipped performance improvements and still has two blocker items."
        }
      },
      "assertions": [
        {
          "path": "success",
          "equals": true
        }
      ]
    },
    {
      "name": "write-industry-news",
      "method": "bridge_tool",
      "params": {
        "tool_name": "file_manager",
        "allowed_tools": ["file_manager"],
        "args": {
          "session_id": "${unique_session_id:agent-loop-shortcuts}",
          "operation": "write",
          "path": "research/industry_news.txt",
          "content": "Industry growth remains supportive and regulation still matters."
        }
      },
      "assertions": [
        {
          "path": "success",
          "equals": true
        }
      ]
    },
    {
      "name": "generate-executive-briefing-via-shortcut",
      "method": "process_prompt",
      "params": {
        "session_id": "${unique_session_id:agent-loop-shortcuts}",
        "prompt": "Review all files in the research/ folder and write a comprehensive daily summary to daily_briefing.md. The summary should be concise and highlight the most important items requiring executive attention."
      },
      "assertions": [
        {
          "path": "text",
          "contains": "daily_briefing.md"
        }
      ]
    },
    {
      "name": "read-generated-briefing",
      "method": "bridge_tool",
      "params": {
        "tool_name": "file_manager",
        "allowed_tools": ["file_manager"],
        "args": {
          "session_id": "${unique_session_id:agent-loop-shortcuts}",
          "operation": "read",
          "path": "daily_briefing.md"
        }
      },
      "assertions": [
        {
          "path": "success",
          "equals": true
        },
        {
          "path": "content",
          "contains": "## Executive Summary"
        },
        {
          "path": "content",
          "contains": "## Recommended Actions"
        },
        {
          "path": "content",
          "contains": "MegaCorp"
        }
      ]
    }
  ]
}
