{
  "name": "email-triage-runtime-contract",
  "offline_safe": true,
  "steps": [
    {
      "name": "create-inbox-directory",
      "method": "bridge_tool",
      "params": {
        "tool_name": "file_manager",
        "allowed_tools": ["file_manager"],
        "args": {
          "session_id": "${unique_session_id:email-triage}",
          "operation": "mkdir",
          "path": "inbox"
        }
      },
      "assertions": [
        {
          "path": "success",
          "equals": true
        }
      ]
    },
    {
      "name": "write-urgent-email",
      "method": "bridge_tool",
      "params": {
        "tool_name": "file_manager",
        "allowed_tools": ["file_manager"],
        "args": {
          "session_id": "${unique_session_id:email-triage}",
          "operation": "write",
          "path": "inbox/email_01.txt",
          "content": "From: cto@example.com\nSubject: URGENT: Production database outage\n\nCustomer-facing services are failing. Join the war room now."
        }
      },
      "assertions": [
        {
          "path": "success",
          "equals": true
        }
      ]
    },
    {
      "name": "write-promo-email",
      "method": "bridge_tool",
      "params": {
        "tool_name": "file_manager",
        "allowed_tools": ["file_manager"],
        "args": {
          "session_id": "${unique_session_id:email-triage}",
          "operation": "write",
          "path": "inbox/email_02.txt",
          "content": "From: deals@saastools.com\nSubject: Flash Sale: 60% off annual plans\n\nUpgrade your workflow with real-time monitoring and dashboards."
        }
      },
      "assertions": [
        {
          "path": "success",
          "equals": true
        }
      ]
    },
    {
      "name": "triage-report-is-created",
      "method": "process_prompt",
      "params": {
        "session_id": "${unique_session_id:email-triage}",
        "prompt": "Read the emails in inbox/ and create a triage report saved to triage_report.md with emails sorted by priority."
      },
      "assertions": [
        {
          "path": "text",
          "contains": "triage_report.md"
        }
      ]
    },
    {
      "name": "triage-report-keeps-promo-email-low-priority",
      "method": "bridge_tool",
      "params": {
        "tool_name": "file_manager",
        "allowed_tools": ["file_manager"],
        "args": {
          "session_id": "${unique_session_id:email-triage}",
          "operation": "read",
          "path": "triage_report.md"
        }
      },
      "assertions": [
        {
          "path": "success",
          "equals": true
        },
        {
          "path": "content",
          "contains": "email_02.txt"
        },
        {
          "path": "content",
          "contains": "P4"
        }
      ]
    }
  ]
}
