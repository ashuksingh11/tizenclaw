{
  "name": "ipc-jsonrpc-contract",
  "steps": [
    {
      "name": "ping-health-check",
      "method": "ping",
      "params": {},
      "assertions": [
        {
          "path": "pong",
          "equals": true
        }
      ]
    },
    {
      "name": "tool-list-shape",
      "method": "tool.list",
      "params": {},
      "assertions": [
        {
          "path": "status",
          "equals": "ok"
        },
        {
          "path": "count",
          "greater_than": 0
        },
        {
          "path": "tools.0.name",
          "exists": true
        },
        {
          "path": "tools.0.description",
          "exists": true
        }
      ]
    },
    {
      "name": "runtime-status-shape",
      "method": "runtime_status",
      "params": {},
      "assertions": [
        {
          "path": "status",
          "equals": "ok"
        },
        {
          "path": "runtime_topology.state_dir",
          "exists": true
        },
        {
          "path": "runtime_topology.sessions_dir",
          "exists": true
        },
        {
          "path": "registrations.tool_paths",
          "exists": true
        },
        {
          "path": "dashboard.name",
          "equals": "web_dashboard"
        }
      ]
    },
    {
      "name": "session-status-shape",
      "method": "session.status",
      "params": {
        "session_id": "ipc-contract"
      },
      "assertions": [
        {
          "path": "status",
          "equals": "ok"
        },
        {
          "path": "session_id",
          "equals": "ipc-contract"
        },
        {
          "path": "runtime_topology.loop_state_dir",
          "exists": true
        },
        {
          "path": "session.resume_ready",
          "exists": true
        }
      ]
    }
  ]
}
