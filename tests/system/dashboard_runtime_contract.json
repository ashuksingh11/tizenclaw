{
  "name": "dashboard-runtime-contract",
  "steps": [
    {
      "name": "dashboard-start-returns-port-and-url",
      "method": "dashboard.start",
      "params": {
        "port": 9191
      },
      "assertions": [
        {
          "path": "status",
          "equals": "ok"
        },
        {
          "path": "name",
          "equals": "web_dashboard"
        },
        {
          "path": "running",
          "equals": true
        },
        {
          "path": "port",
          "equals": 9191
        },
        {
          "path": "url",
          "equals": "http://127.0.0.1:9191"
        }
      ]
    },
    {
      "name": "dashboard-status-shows-runtime-url",
      "method": "dashboard.status",
      "params": {},
      "assertions": [
        {
          "path": "name",
          "equals": "web_dashboard"
        },
        {
          "path": "running",
          "equals": true
        },
        {
          "path": "port",
          "equals": 9191
        },
        {
          "path": "url",
          "equals": "http://127.0.0.1:9191"
        }
      ]
    },
    {
      "name": "dashboard-stop-succeeds",
      "method": "dashboard.stop",
      "params": {},
      "assertions": [
        {
          "path": "status",
          "equals": "ok"
        },
        {
          "path": "name",
          "equals": "web_dashboard"
        }
      ]
    }
  ]
}
