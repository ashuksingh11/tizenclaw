{
  "name": "research-grounding-runtime-contract",
  "steps": [
    {
      "name": "research-prompt-produces-session-output",
      "method": "process_prompt",
      "params": {
        "session_id": "${unique_session_id:research-grounding}",
        "prompt": "Find 3 upcoming technology conferences and create events.md with name, date, location, and website for each. Save the result as markdown with a heading and either a table or bullet list."
      },
      "assertions": [
        {
          "path": "session_id",
          "exists": true
        },
        {
          "path": "text",
          "exists": true
        }
      ]
    },
    {
      "name": "research-session-runtime-reports-transcript",
      "method": "get_session_runtime",
      "params": {
        "session_id": "${unique_session_id:research-grounding}"
      },
      "assertions": [
        {
          "path": "status",
          "equals": "ok"
        },
        {
          "path": "session.transcript_exists",
          "equals": true
        },
        {
          "path": "session.assistant_message_count",
          "greater_than": 0
        },
        {
          "path": "session.resume_ready",
          "equals": true
        }
      ]
    }
  ]
}
