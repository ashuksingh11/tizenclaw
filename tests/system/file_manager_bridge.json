{
  "name": "file-manager-bridge",
  "offline_safe": true,
  "steps": [
    {
      "name": "mkdir-via-linux-utility",
      "method": "bridge_tool",
      "params": {
        "tool_name": "file_manager",
        "allowed_tools": ["file_manager"],
        "args": {
          "session_id": "system-file-manager-observability",
          "operation": "mkdir",
          "path": "tree/subdir"
        }
      },
      "assertions": [
        {
          "path": "success",
          "equals": true
        },
        {
          "path": "backend",
          "equals": "linux_utility"
        }
      ]
    },
    {
      "name": "write-seed-file",
      "method": "bridge_tool",
      "params": {
        "tool_name": "file_manager",
        "allowed_tools": ["file_manager"],
        "args": {
          "session_id": "system-file-manager-observability",
          "operation": "write",
          "path": "tree/subdir/input.txt",
          "content": "alpha\\n"
        }
      },
      "assertions": [
        {
          "path": "success",
          "equals": true
        }
      ]
    },
    {
      "name": "read-via-linux-utility",
      "method": "bridge_tool",
      "params": {
        "tool_name": "file_manager",
        "allowed_tools": ["file_manager"],
        "args": {
          "session_id": "system-file-manager-observability",
          "operation": "read",
          "path": "tree/subdir/input.txt"
        }
      },
      "assertions": [
        {
          "path": "success",
          "equals": true
        },
        {
          "path": "backend",
          "equals": "linux_utility"
        },
        {
          "path": "content",
          "contains": "alpha"
        }
      ]
    },
    {
      "name": "read-via-rust-fallback",
      "method": "bridge_tool",
      "params": {
        "tool_name": "file_manager",
        "allowed_tools": ["file_manager"],
        "args": {
          "session_id": "system-file-manager-observability",
          "operation": "read",
          "path": "tree/subdir/input.txt",
          "backend_preference": "rust_fallback"
        }
      },
      "assertions": [
        {
          "path": "success",
          "equals": true
        },
        {
          "path": "backend",
          "equals": "rust_fallback"
        },
        {
          "path": "content",
          "contains": "alpha"
        }
      ]
    },
    {
      "name": "list-via-linux-utility",
      "method": "bridge_tool",
      "params": {
        "tool_name": "file_manager",
        "allowed_tools": ["file_manager"],
        "args": {
          "session_id": "system-file-manager-observability",
          "operation": "list",
          "path": "tree"
        }
      },
      "assertions": [
        {
          "path": "success",
          "equals": true
        },
        {
          "path": "backend",
          "equals": "linux_utility"
        },
        {
          "path": "entries.0.name",
          "equals": "subdir"
        }
      ]
    },
    {
      "name": "stat-via-rust-fallback",
      "method": "bridge_tool",
      "params": {
        "tool_name": "file_manager",
        "allowed_tools": ["file_manager"],
        "args": {
          "session_id": "system-file-manager-observability",
          "operation": "stat",
          "path": "tree/subdir/input.txt",
          "backend_preference": "rust_fallback"
        }
      },
      "assertions": [
        {
          "path": "success",
          "equals": true
        },
        {
          "path": "backend",
          "equals": "rust_fallback"
        },
        {
          "path": "is_file",
          "equals": true
        }
      ]
    },
    {
      "name": "copy-via-linux-utility",
      "method": "bridge_tool",
      "params": {
        "tool_name": "file_manager",
        "allowed_tools": ["file_manager"],
        "args": {
          "session_id": "system-file-manager-observability",
          "operation": "copy",
          "src": "tree/subdir/input.txt",
          "dst": "tree/subdir/copied.txt"
        }
      },
      "assertions": [
        {
          "path": "success",
          "equals": true
        },
        {
          "path": "backend",
          "equals": "linux_utility"
        }
      ]
    },
    {
      "name": "move-via-rust-fallback",
      "method": "bridge_tool",
      "params": {
        "tool_name": "file_manager",
        "allowed_tools": ["file_manager"],
        "args": {
          "session_id": "system-file-manager-observability",
          "operation": "move",
          "src": "tree/subdir/copied.txt",
          "dst": "tree/subdir/moved.txt",
          "backend_preference": "rust_fallback"
        }
      },
      "assertions": [
        {
          "path": "success",
          "equals": true
        },
        {
          "path": "backend",
          "equals": "rust_fallback"
        }
      ]
    },
    {
      "name": "remove-file-via-linux-utility",
      "method": "bridge_tool",
      "params": {
        "tool_name": "file_manager",
        "allowed_tools": ["file_manager"],
        "args": {
          "session_id": "system-file-manager-observability",
          "operation": "remove",
          "path": "tree/subdir/moved.txt"
        }
      },
      "assertions": [
        {
          "path": "success",
          "equals": true
        },
        {
          "path": "backend",
          "equals": "linux_utility"
        }
      ]
    },
    {
      "name": "remove-tree-via-rust-fallback",
      "method": "bridge_tool",
      "params": {
        "tool_name": "file_manager",
        "allowed_tools": ["file_manager"],
        "args": {
          "session_id": "system-file-manager-observability",
          "operation": "remove",
          "path": "tree",
          "backend_preference": "rust_fallback"
        }
      },
      "assertions": [
        {
          "path": "success",
          "equals": true
        },
        {
          "path": "backend",
          "equals": "rust_fallback"
        }
      ]
    }
  ]
}
