{
  "name": "context-compaction-runtime-contract",
  "steps": [
    {
      "name": "set-small-context-budget",
      "method": "set_llm_config",
      "params": {
        "path": "backends.context_token_budget",
        "value": 1
      },
      "assertions": [
        {
          "path": "value",
          "equals": 1
        }
      ]
    },
    {
      "name": "set-low-compaction-threshold",
      "method": "set_llm_config",
      "params": {
        "path": "backends.context_compact_threshold",
        "value": 0.5
      },
      "assertions": [
        {
          "path": "value",
          "equals": 0.5
        }
      ]
    },
    {
      "name": "prompt-generates-compacted-session-snapshot",
      "method": "process_prompt",
      "params": {
        "session_id": "${unique_session_id:context-compaction}",
        "prompt": "Summarize this request in one sentence and stay concise. This prompt exists to force context compaction under a tiny token budget."
      },
      "assertions": [
        {
          "path": "session_id",
          "exists": true
        },
        {
          "path": "text",
          "exists": true
        }
      ]
    },
    {
      "name": "session-runtime-reports-compacted-snapshot",
      "method": "get_session_runtime",
      "params": {
        "session_id": "${unique_session_id:context-compaction}"
      },
      "assertions": [
        {
          "path": "status",
          "equals": "ok"
        },
        {
          "path": "session.compacted_snapshot_exists",
          "equals": true
        },
        {
          "path": "session.structured_compaction_exists",
          "equals": true
        },
        {
          "path": "session.compacted_path",
          "contains": "compacted.md"
        },
        {
          "path": "session.resume_ready",
          "equals": true
        }
      ]
    },
    {
      "name": "unset-small-context-budget",
      "method": "unset_llm_config",
      "params": {
        "path": "backends.context_token_budget"
      },
      "assertions": [
        {
          "path": "removed",
          "equals": 1
        }
      ]
    },
    {
      "name": "unset-low-compaction-threshold",
      "method": "unset_llm_config",
      "params": {
        "path": "backends.context_compact_threshold"
      },
      "assertions": [
        {
          "path": "removed",
          "equals": 0.5
        }
      ]
    }
  ]
}
