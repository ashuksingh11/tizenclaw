{
  "name": "dashboard-manual-enable",
  "steps": [
    {
      "name": "dashboard-default-stopped",
      "method": "channel_status",
      "params": {
        "name": "web_dashboard"
      },
      "assertions": [
        {
          "path": "name",
          "equals": "web_dashboard"
        },
        {
          "path": "running",
          "equals": false
        }
      ]
    },
    {
      "name": "start-dashboard-on-demand",
      "method": "start_channel",
      "params": {
        "name": "web_dashboard"
      },
      "assertions": [
        {
          "path": "status",
          "equals": "ok"
        },
        {
          "path": "name",
          "equals": "web_dashboard"
        }
      ]
    },
    {
      "name": "dashboard-running-after-manual-start",
      "method": "channel_status",
      "params": {
        "name": "web_dashboard"
      },
      "assertions": [
        {
          "path": "running",
          "equals": true
        }
      ]
    },
    {
      "name": "stop-dashboard-after-check",
      "method": "stop_channel",
      "params": {
        "name": "web_dashboard"
      },
      "assertions": [
        {
          "path": "status",
          "equals": "ok"
        }
      ]
    }
  ]
}
