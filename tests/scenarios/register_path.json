{
  "name": "register-path",
  "steps": [
    {
      "name": "register-tool-path",
      "method": "register_path",
      "params": {
        "kind": "tool",
        "path": "tests/scenarios"
      },
      "assertions": [
        {
          "path": "status",
          "equals": "ok"
        },
        {
          "path": "registrations.tool_paths",
          "contains": "tests/scenarios"
        }
      ]
    },
    {
      "name": "runtime-status-reflects-path",
      "method": "runtime_status",
      "params": {},
      "assertions": [
        {
          "path": "status",
          "equals": "ok"
        },
        {
          "path": "registrations.tool_paths",
          "contains": "tests/scenarios"
        }
      ]
    }
  ]
}
