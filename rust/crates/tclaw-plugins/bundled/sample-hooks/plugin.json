{
  "schema_version": 1,
  "name": "sample-hooks",
  "kind": "tooling",
  "summary": "Bundled plugin used to exercise hook execution",
  "metadata": {
    "version": "1.0.0",
    "description": "Sample hook-only bundled plugin for tests.",
    "authors": ["TizenClaw"],
    "tags": ["bundled", "hooks"]
  },
  "lifecycle": {
    "default_phase": "loaded",
    "hooks": [
      {
        "name": "sample-pre",
        "phase": "pre_prompt",
        "command": "hooks/pre.sh",
        "enabled": true
      },
      {
        "name": "sample-post",
        "phase": "post_session",
        "command": "hooks/post.sh",
        "enabled": true
      }
    ]
  },
  "tools": [
    {
      "name": "sample-hooks.inspect",
      "description": "Inspect bundled hook metadata",
      "input_schema": {
        "type": "object",
        "properties": {}
      },
      "permissions": {
        "scope": "read",
        "level": "low",
        "target": "plugin-hooks"
      },
      "tags": ["hooks"]
    }
  ]
}
