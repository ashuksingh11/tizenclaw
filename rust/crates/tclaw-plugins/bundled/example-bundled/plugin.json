{
  "schema_version": 1,
  "name": "example-bundled",
  "kind": "metadata",
  "summary": "Bundled metadata plugin example",
  "metadata": {
    "version": "1.0.0",
    "description": "Bundled plugin that exposes metadata commands and tools.",
    "authors": ["TizenClaw"],
    "tags": ["bundled", "metadata"]
  },
  "permissions": [
    {
      "scope": "read",
      "level": "standard",
      "target": "plugin-registry"
    }
  ],
  "lifecycle": {
    "default_phase": "discovered",
    "hooks": [
      {
        "name": "example-pre",
        "phase": "pre_tool",
        "command": "hooks/pre.sh",
        "enabled": true,
        "env": {
          "EXAMPLE_PLUGIN": "bundled"
        }
      },
      {
        "name": "example-post",
        "phase": "post_session",
        "command": "hooks/post.sh",
        "enabled": true
      }
    ]
  },
  "commands": [
    {
      "name": "metadata.sync",
      "summary": "Refresh plugin metadata and command annotations",
      "aliases": ["meta-sync"],
      "argument_hints": [
        {
          "name": "scope",
          "summary": "Optional metadata scope to refresh",
          "required": false,
          "repeatable": false
        }
      ]
    },
    {
      "name": "metadata.resume",
      "summary": "Inspect plugin-provided resume markers",
      "aliases": ["meta-resume"],
      "argument_hints": [
        {
          "name": "session",
          "summary": "Optional session identifier to inspect",
          "required": false,
          "repeatable": false
        }
      ],
      "resume_behavior": "supported"
    }
  ],
  "tools": [
    {
      "name": "metadata.sync",
      "description": "Refresh metadata-derived tool annotations",
      "input_schema": {
        "type": "object",
        "properties": {
          "scope": {
            "type": "string"
          }
        }
      },
      "permissions": {
        "scope": "read",
        "level": "standard",
        "target": "plugin-registry"
      },
      "tags": ["metadata", "bundled"]
    },
    {
      "name": "metadata.resume",
      "description": "Inspect plugin-provided resume markers",
      "input_schema": {
        "type": "object",
        "properties": {
          "session": {
            "type": "string"
          }
        }
      },
      "permissions": {
        "scope": "read",
        "level": "standard",
        "target": "plugin-resume-state"
      },
      "tags": ["metadata", "resume"]
    }
  ]
}
