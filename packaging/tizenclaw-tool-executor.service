[Unit]
Description=TizenClaw Tool Executor
Requires=tizenclaw-tool-executor.socket
After=tizenclaw-tool-executor.socket

[Service]
Type=simple
Environment="HOME=/home/owner"
Environment="TIZENCLAW_HOME=/home/owner/.tizenclaw"
Environment="TIZENCLAW_PACKAGED_DIR=/opt/usr/share/tizenclaw"
ExecStart=/usr/bin/tizenclaw-tool-executor
User=owner
Group=users
Restart=on-failure
RestartSec=3
